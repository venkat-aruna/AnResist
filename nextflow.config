// nextflow.config
profiles {

    conda {
        conda.enabled          = true
        conda.useMamba         = true
        process.conda          = "amr-compare"
    }

    docker {
        docker.enabled         = true
        docker.userEmulation   = true
    }

    local {
        process.executor       = 'local'
        process.cpus           = 4
        process.memory         = '8 GB'
    }
}

// default params — overridden by params.yml or CLI flags
params {
    samplesheet    = "config/samplesheet.csv"
    outdir         = "results"
    run_amrfinder  = true
    run_rgi        = true
    run_abricate   = true
    run_resfinder  = true
    run_staramr    = true
    run_fargene    = true
}